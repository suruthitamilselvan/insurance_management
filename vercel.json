{
  "buildCommand": "cd secureshield-frontend && npm install && npm run build",
  "outputDirectory": "secureshield-frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://insurance-management-78ha.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
